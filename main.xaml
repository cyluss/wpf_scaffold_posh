<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Hello WPF"
    Width="400" Height="300"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanMinimize">

    <StackPanel Margin="20" VerticalAlignment="Center">
        <Label Content="Enter your name:" FontSize="14"/>
        <TextBox x:Name="txtName" FontSize="14" Padding="5" Margin="0,0,0,10"/>
        <Button x:Name="btnHello" Content="Say Hello"
                FontSize="14" Padding="10,5" HorizontalAlignment="Left"
                Click="Invoke-HelloClick"/>
        <TextBlock x:Name="lblOutput" FontSize="20" FontWeight="Bold"
                   Margin="0,20,0,0" Foreground="#2196F3"/>
        <TextBlock x:Name="lblClock" FontSize="12" Foreground="#888"
                   Margin="0,8,0,0" HorizontalAlignment="Right"/>
    </StackPanel>
</Window>
