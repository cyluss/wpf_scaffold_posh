<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="HTTP Client"
    Width="820" Height="650"
    WindowStartupLocation="CenterScreen"
    Loaded="Initialize-Wsl">

    <DockPanel Margin="10">

        <!-- Row 1: Method + URL + Send + Cancel -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
            <ComboBox x:Name="cboMethod" Width="90" FontSize="13" FontFamily="Consolas"
                      SelectedIndex="0" DockPanel.Dock="Left" Margin="0,0,6,0">
                <ComboBoxItem Content="GET"/>
                <ComboBoxItem Content="POST"/>
                <ComboBoxItem Content="PUT"/>
                <ComboBoxItem Content="PATCH"/>
                <ComboBoxItem Content="DELETE"/>
                <ComboBoxItem Content="HEAD"/>
                <ComboBoxItem Content="OPTIONS"/>
            </ComboBox>
            <Button x:Name="btnCancel" Content="Cancel" FontSize="13" Padding="12,4"
                    DockPanel.Dock="Right" Margin="6,0,0,0" IsEnabled="False"
                    Click="Invoke-CancelClick"/>
            <Button x:Name="btnSend" Content="Send" FontSize="13" Padding="12,4"
                    DockPanel.Dock="Right"
                    Click="Invoke-SendClick"/>
            <TextBox x:Name="txtUrl" FontSize="13" FontFamily="Consolas" Padding="4"
                     Text="https://httpbin.org/get"
                     KeyDown="Invoke-UrlKeyDown"/>
        </DockPanel>

        <!-- Row 2: TLS Verify + Body Type + WSL -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
            <CheckBox x:Name="chkTls" Content="TLS Verify" FontSize="13"
                      IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0"/>
            <TextBlock Text="Body:" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="cboBodyType" Width="90" FontSize="13" SelectedIndex="0">
                <ComboBoxItem Content="None"/>
                <ComboBoxItem Content="JSON"/>
                <ComboBoxItem Content="Form"/>
                <ComboBoxItem Content="Text"/>
            </ComboBox>
            <Button x:Name="btnWsl" Content="WSL SysInfo" FontSize="13" Padding="12,4"
                    Margin="16,0,0,0"
                    Click="Invoke-WslClick"/>
        </StackPanel>

        <!-- Row 3: Headers label + textbox -->
        <TextBlock DockPanel.Dock="Top" Text="Headers" FontSize="12" Foreground="#888"
                   Margin="0,0,0,2"/>
        <TextBox x:Name="txtHeaders" DockPanel.Dock="Top" FontSize="12" FontFamily="Consolas"
                 Height="60" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" Padding="4"/>

        <!-- Row 4: Body label + textbox -->
        <TextBlock DockPanel.Dock="Top" Text="Body" FontSize="12" Foreground="#888"
                   Margin="0,6,0,2"/>
        <TextBox x:Name="txtBody" DockPanel.Dock="Top" FontSize="12" FontFamily="Consolas"
                 Height="80" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" Padding="4"/>

        <!-- Row 5: Status bar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,6,0,2">
            <TextBlock x:Name="lblClock" FontSize="12" Foreground="#888"
                       DockPanel.Dock="Right" HorizontalAlignment="Right"/>
            <TextBlock x:Name="lblStatus" FontSize="13" FontWeight="SemiBold"
                       Foreground="#4CAF50"/>
        </DockPanel>

        <!-- Row 6: Response label -->
        <TextBlock DockPanel.Dock="Top" Text="Response" FontSize="12" Foreground="#888"
                   Margin="0,0,0,2"/>

        <!-- Response fills remaining space -->
        <TextBox x:Name="txtResponse" FontSize="12" FontFamily="Consolas"
                 IsReadOnly="True" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" Padding="4"/>

    </DockPanel>
</Window>
